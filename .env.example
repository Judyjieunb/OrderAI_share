# order-ai-share — 환경 변수 템플릿
#
# 사용법:
#   cp .env.example .env
#   # 아래에서 본인이 선택한 인증 모드의 값들을 채움
#   # .env 는 .gitignore — 절대 git 커밋 X
#
# 보안 노트:
#   - SSO 모드 권장 (Credential .env 보관 불필요)
#   - Password 모드 시 1Password share / GPG encrypted file 로만 전달
#   - plain email / Slack DM / USB unencrypted 금지

# ============================================================
# Snowflake 인증 — 두 모드 중 선택
# ============================================================

# 공통 (양쪽 모드 모두 필요)
SNOWFLAKE_ACCOUNT=your_account.ap-northeast-2
SNOWFLAKE_USER=your.email@fnf.co.kr
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=FNF
SNOWFLAKE_SCHEMA=PRCS
SNOWFLAKE_ROLE=                         # 선택 — SSO 모드면 본인 default role 자동 사용

# ─── 옵션 A: SSO (externalbrowser) — 권장 ──────────────────
# 사용자 본인 Snowflake login 사용. 브랜드 권한이 본인 role 에 자동 반영.
# 사용 시 아래 한 줄 주석 해제:
# SNOWFLAKE_AUTH=externalbrowser
# 이 모드에선 SNOWFLAKE_PASSWORD 무시됨.

# ─── 옵션 B: Service Account + Password — 헤드리스 환경용 ────
# IT 에서 발급한 service account credentials.
# 사용 시 아래 password 채움 (SNOWFLAKE_AUTH 줄은 제거/비활성):
SNOWFLAKE_PASSWORD=

# ============================================================
# 운영 설정
# ============================================================

BRAND=MLB                               # 대문자, brand_config.json::brand 와 일치
SINGLE_BRAND_MODE=true
DUCKDB_PATH=data/production/order_ai.duckdb
USER_STORAGE_PATH=data/user-storage
